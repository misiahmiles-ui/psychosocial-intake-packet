NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase buyer account/access settings.
# These are for user login and paid access only, not packet/client data storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe checkout settings.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: use a prebuilt Stripe Price ID.
# If omitted, checkout creates a one-time $497 line item from STANDARD_ACCESS_PRICE_CENTS.
STRIPE_STANDARD_ACCESS_PRICE_ID=
STANDARD_ACCESS_PRICE_CENTS=49700
