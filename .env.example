NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase buyer account/access settings.
# These are for user login and paid access only, not packet/client data storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe checkout settings.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: use prebuilt Stripe Price IDs.
# If omitted, checkout creates inline prices for $487 up front plus $19/month.
STRIPE_STANDARD_ACCESS_UPFRONT_PRICE_ID=
STRIPE_STANDARD_ACCESS_MONTHLY_PRICE_ID=
STANDARD_ACCESS_UPFRONT_PRICE_CENTS=48700
STANDARD_ACCESS_MONTHLY_PRICE_CENTS=1900
