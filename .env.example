NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase buyer account/access settings.
# These are for user login and paid access only, not packet/client data storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared suite access is enabled after applying the approved migration to Intake Onboarding App.
SHARED_SUITE_ACCESS_ENABLED=true

# Stripe checkout settings.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: use prebuilt Stripe Price IDs.
# If omitted, checkout creates inline prices for $487 up front plus $19/month.
STRIPE_STANDARD_ACCESS_UPFRONT_PRICE_ID=
STRIPE_STANDARD_ACCESS_MONTHLY_PRICE_ID=
STANDARD_ACCESS_UPFRONT_PRICE_CENTS=48700
STANDARD_ACCESS_MONTHLY_PRICE_CENTS=1900

# Shared Suite and single-product-to-Suite upgrade Price IDs.
STRIPE_SUITE_UPFRONT_PRICE_ID=
STRIPE_SUITE_MONTHLY_PRICE_ID=
STRIPE_SUITE_UPGRADE_UPFRONT_PRICE_ID=

# Additional named workflow seats. Single-product seats are $9/month; Suite seats are $7/month.
STRIPE_PSYCHOSOCIAL_ADDITIONAL_SEAT_MONTHLY_PRICE_ID=
STRIPE_NURSING_ADDITIONAL_SEAT_MONTHLY_PRICE_ID=
STRIPE_SUITE_PSYCHOSOCIAL_ADDITIONAL_SEAT_MONTHLY_PRICE_ID=
STRIPE_SUITE_NURSING_ADDITIONAL_SEAT_MONTHLY_PRICE_ID=
